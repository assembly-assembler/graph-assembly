---
const base = import.meta.env.BASE_URL
const { title = '국회 의정활동 위키' } = Astro.props
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="제22대 국회 의석·의원·발의법안·표결을 출처와 함께 보기 쉽게 정리한 위키." />
  </head>
  <body>
    <header class="site">
      <a class="brand" href={base}>🏛️ 국회 의정활동 위키</a>
      <span class="sub">제22대 · 데이터: 열린국회정보</span>
    </header>
    <main><slot /></main>
    <footer class="site">
      <p>
        출처: <a href="https://open.assembly.go.kr" target="_blank" rel="noopener">열린국회정보</a> OpenAPI ·
        모든 데이터에 출처 표기 · 런타임 LLM 0 · <a href="https://github.com/assembly-assembler" target="_blank" rel="noopener">소스</a>
      </p>
    </footer>

    <style is:global>
      :root {
        --bg: #fff; --fg: #1a1a1a; --muted: #666; --line: #e5e5e5;
        --accent: #1746a2; --chip: #f1f3f8;
        font-family: system-ui, -apple-system, 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; color: var(--fg); background: var(--bg); line-height: 1.5; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header.site { display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap;
        padding: 1rem 1.25rem; border-bottom: 1px solid var(--line); }
      header.site .brand { font-weight: 700; font-size: 1.1rem; color: var(--fg); }
      header.site .sub { color: var(--muted); font-size: .85rem; }
      main { max-width: 980px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
      footer.site { border-top: 1px solid var(--line); padding: 1.25rem; color: var(--muted);
        font-size: .8rem; text-align: center; }
      h1 { font-size: 1.5rem; margin: 0 0 .75rem; }
      .count { color: var(--accent); }
      .parties { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1rem; }
      .chip { background: var(--chip); border-radius: 999px; padding: .25rem .7rem; font-size: .8rem; }
      input[type=search] { width: 100%; padding: .65rem .9rem; font-size: 1rem;
        border: 1px solid var(--line); border-radius: 8px; margin-bottom: 1.25rem; }
      .grid { list-style: none; padding: 0; margin: 0;
        display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: .75rem; }
      .card a { display: flex; gap: .6rem; align-items: center; padding: .55rem;
        border: 1px solid var(--line); border-radius: 10px; color: var(--fg); }
      .card a:hover { border-color: var(--accent); text-decoration: none; background: #fafbff; }
      .card img { border-radius: 6px; object-fit: cover; background: var(--chip); flex: none; }
      .card strong { display: block; }
      .card small { display: block; color: var(--muted); font-size: .78rem; }
      .back { display: inline-block; margin-bottom: 1rem; font-size: .9rem; }
      .profile { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: flex-start; }
      .profile img { border-radius: 10px; object-fit: cover; background: var(--chip); flex: none; }
      .profile h1 { margin: 0 0 .25rem; }
      .profile h1 small { color: var(--muted); font-weight: 400; font-size: 1rem; }
      .profile .meta { color: var(--accent); font-weight: 600; margin: 0 0 .75rem; }
      .profile p { margin: .3rem 0; }
      .profile .contact { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: .75rem; color: var(--muted); }
      .profile .source { margin-top: 1rem; font-size: .78rem; color: var(--muted); }
      .todo { margin-top: 2rem; padding: 1rem 1.25rem; background: var(--chip); border-radius: 10px; }
      .todo h2 { margin: 0 0 .4rem; font-size: 1.05rem; }
      .todo p { margin: 0; color: var(--muted); font-size: .9rem; }
    </style>
  </body>
</html>
