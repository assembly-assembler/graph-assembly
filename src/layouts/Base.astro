---
const base = import.meta.env.BASE_URL
const { title = '국회의 활동을 한 눈에', hero = false } = Astro.props
const TERM = '2024.05.30 ~ 2028.05.29'
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="제22대 국회 — 의원별 발의·표결 의정활동을 월별로, 출처와 함께." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  </head>
  <body>
    {hero ? (
      <header class="hero">
        <p class="term">제22대 국회 · {TERM}</p>
        <h1 class="wordmark"><a href={base}>국회의 활동을<br />한 눈에</a></h1>
      </header>
    ) : (
      <header class="bar">
        <a class="brand" href={base}>국회의 활동을 한 눈에</a>
        <span class="sub">제22대 · {TERM}</span>
      </header>
    )}
    <main><slot /></main>

    <!-- 법안 원문(제안이유·주요내용) 모달. 출처: 의안정보시스템 -->
    <div id="srcModal" class="src-modal" hidden>
      <div class="src-modal-card" role="dialog" aria-modal="true" aria-labelledby="srcModalTitle">
        <div class="src-modal-head">
          <strong id="srcModalTitle"></strong>
          <button type="button" id="srcModalClose" aria-label="닫기">✕</button>
        </div>
        <p class="src-modal-kicker">제안이유 및 주요내용</p>
        <div id="srcModalBody" class="src-modal-body"></div>
        <p class="src-modal-src">출처 · 의안정보시스템(likms.assembly.go.kr)</p>
      </div>
    </div>

    <style is:global>
      :root {
        --canvas:#fff; --ink:#171717; --body:#171717; --muted:#4d4d4d; --muted-soft:#767676;
        --hairline:#f0f0f3; --hairline-strong:#dcdee0; --surface-strong:#f0f0f3;
        --primary:#000; --link:#0d74ce;
        --ok:#0f7a30; --ok-bg:#e7f5ea; --no:#b32424; --no-bg:#f7eaea; --pend:#8a6d00; --pend-bg:#f7f1dd;
        font-family:'Inter',-apple-system,system-ui,'Apple SD Gothic Neo','Malgun Gothic',sans-serif;
      }
      * { box-sizing:border-box; }
      body { margin:0; color:var(--ink); background:var(--canvas); line-height:1.5; -webkit-font-smoothing:antialiased; }
      a { color:var(--ink); text-decoration:none; }
      code { font-family:'JetBrains Mono',ui-monospace,monospace; font-size:12.5px; background:var(--surface-strong); padding:.08rem .3rem; }
      main { max-width:1160px; margin:0 auto; padding:.5rem 1.5rem 5rem; }

      /* ── 히어로 (index) ── */
      header.hero { text-align:center; padding:3.5rem 1.5rem 1rem; }
      header.hero .term { font-size:13px; color:var(--muted); margin:0 0 1rem; letter-spacing:.02em; font-variant-numeric:tabular-nums; }
      header.hero .wordmark { margin:0; }
      header.hero .wordmark a { color:var(--ink); font-weight:800; font-size:clamp(30px,6vw,60px); letter-spacing:-.035em; line-height:1.05; display:inline-block; }

      /* ── 컴팩트 바 (내부 페이지) ── */
      header.bar { display:flex; align-items:center; gap:.7rem; height:60px; padding:0 1.5rem;
        border-bottom:1px solid var(--hairline); position:sticky; top:0; background:var(--canvas); z-index:5; }
      header.bar .brand { font-weight:700; letter-spacing:-.02em; font-size:16px; }
      header.bar .sub { color:var(--muted); font-size:12.5px; font-variant-numeric:tabular-nums; }

      /* ── 월 이동 ── */
      .monthnav { display:flex; align-items:center; justify-content:center; gap:1.75rem; margin:1.75rem 0 2.25rem; }
      .monthnav .mlabel { font-size:23px; font-weight:700; letter-spacing:-.4px; min-width:9.5rem; text-align:center; font-variant-numeric:tabular-nums; }
      .monthnav .arr { font-size:30px; line-height:1; color:var(--ink); padding:0 .25rem; user-select:none; }
      .monthnav a.arr:hover { color:var(--link); }
      .monthnav .arr.off { color:var(--muted-soft); pointer-events:none; }

      /* ── 카드 그리드 ── */
      .cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:1rem; }

      /* ── 카드 = 내부 카드뉴스 (크고 각지고 진한 테두리) ── */
      .acard { display:flex; flex-direction:column; min-height:236px; background:#fff;
        border:1.5px solid var(--ink); border-radius:0; }
      .acard-top { display:flex; align-items:center; justify-content:space-between; padding:.55rem .7rem; border-bottom:1px solid var(--hairline); }
      .acard-top button { border:none; background:none; font-size:20px; line-height:1; cursor:pointer; color:var(--ink); padding:0 .4rem; }
      .acard-top button:hover { color:var(--link); }
      .dots { display:flex; gap:5px; flex-wrap:wrap; max-width:70%; justify-content:center; }
      .dots i { width:6px; height:6px; background:var(--hairline-strong); display:inline-block; }
      .dots i.on { background:var(--ink); }
      .pages { flex:1; padding:1.15rem 1.15rem .4rem; }
      .page.count { display:flex; flex-direction:column; }
      .page.count .crow { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; }
      .page.count .who { min-width:0; }
      .page.count .wname { font-size:21px; font-weight:700; letter-spacing:-.02em; display:block; }
      .page.count .wmeta { font-size:13px; color:var(--body); }
      .page.count .num { flex:none; text-align:right; }
      .page.count .numline { line-height:.9; }
      .page.count .big { font-size:56px; font-weight:800; letter-spacing:-.04em; }
      .page.count .unit { font-size:15px; color:var(--body); margin-left:.1rem; }
      .page.count .total { display:block; font-size:12px; color:var(--muted); margin-top:.35rem; white-space:nowrap; font-variant-numeric:tabular-nums; }
      .page.count .vsum { margin-top:1.2rem; font-size:12.5px; color:var(--muted); font-variant-numeric:tabular-nums; }
      .page.bill .btitle { font-size:13px; font-weight:600; color:var(--muted); margin:0 0 .55rem; line-height:1.4;
        display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
      .page.bill .bdesc { font-size:15px; color:var(--ink); margin:0 0 .55rem; min-height:2.6em; line-height:1.45; }
      .page.bill .bdesc .todo { color:var(--muted); }
      /* 개선 전 → (가로선) → 개선 후 */
      .page.bill .ba { margin:0 0 .55rem; }
      .page.bill .ba-row { padding:0; }
      .page.bill .ba-row.after { margin-top:.6rem; padding-top:.6rem; border-top:1px solid var(--hairline-strong); }
      .page.bill .ba-label { display:block; font-size:11px; font-weight:600; letter-spacing:.02em; color:var(--muted-soft); margin-bottom:.18rem; }
      .page.bill .ba-row.after .ba-label { color:var(--ink); }
      .page.bill .ba-row p { margin:0; font-size:14.5px; line-height:1.45; color:var(--ink); }
      .page.bill .ba-row:not(.after) p { color:var(--muted); }
      .page.bill .src-open { display:inline-block; margin:0 0 .7rem; padding:0; border:none; background:none;
        font:inherit; font-size:12.5px; color:var(--link); cursor:pointer; }
      .page.bill .src-open::before { content:'▸ '; }
      .page.bill .src-open:hover { text-decoration:underline; }
      .page.bill .bfacts { font-size:12.5px; color:var(--body); }

      /* ── 원문 모달 ── */
      .src-modal { position:fixed; inset:0; z-index:50; display:flex; align-items:center; justify-content:center;
        padding:1.5rem; background:rgba(23,23,23,.45); }
      .src-modal[hidden] { display:none; }
      .src-modal-card { background:#fff; border:1.5px solid var(--ink); border-radius:0; width:min(640px,100%);
        max-height:85vh; display:flex; flex-direction:column; padding:1.4rem 1.5rem 1.2rem; }
      .src-modal-head { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; }
      .src-modal-head strong { font-size:17px; font-weight:700; letter-spacing:-.02em; line-height:1.35; }
      .src-modal-head button { flex:none; border:none; background:none; font-size:19px; line-height:1; cursor:pointer; color:var(--muted); padding:.1rem .2rem; }
      .src-modal-head button:hover { color:var(--ink); }
      .src-modal-kicker { margin:.7rem 0 .5rem; font-size:12px; font-weight:600; color:var(--muted); letter-spacing:.02em; }
      .src-modal-body { overflow-y:auto; font-size:14.5px; line-height:1.65; color:var(--ink); white-space:pre-wrap; word-break:break-word; }
      .src-modal-src { margin:1rem 0 0; padding-top:.8rem; border-top:1px solid var(--hairline); font-size:11.5px; color:var(--muted-soft); }
      .tomember { display:block; padding:.65rem 1.15rem; border-top:1px solid var(--hairline); font-size:13px; color:var(--body); }
      .tomember:hover { color:var(--ink); }

      /* 처리결과 태그 */
      .tag { font-size:11px; font-weight:600; padding:.12rem .42rem; background:var(--surface-strong); color:var(--body); white-space:nowrap; }
      .tag.ok { color:var(--ok); background:var(--ok-bg); }
      .tag.no { color:var(--no); background:var(--no-bg); }
      .tag.pend { color:var(--pend); background:var(--pend-bg); }

      /* ── 이번 달 대표발의 0건 ── */
      .inactive { margin-top:3rem; padding-top:1.75rem; border-top:1px solid var(--hairline); }
      .inactive h2 { font-size:16px; font-weight:600; margin:0 0 1rem; }
      ul.namelist { list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:.5rem .9rem; }
      ul.namelist li { font-size:14px; }
      ul.namelist a { color:var(--body); }
      ul.namelist a:hover { color:var(--ink); }
      ul.namelist small { color:var(--muted-soft); font-size:11px; margin-left:.2rem; }

      /* ── 의원 상세 ── */
      .back { display:inline-block; margin:1rem 0 1.5rem; font-size:14px; color:var(--body); }
      .back:hover { color:var(--ink); }
      .profile { display:flex; gap:1.5rem; flex-wrap:wrap; align-items:flex-start; }
      .profile img { border-radius:0; object-fit:cover; background:var(--surface-strong); flex:none; border:1.5px solid var(--ink); }
      .profile h1 { margin:0 0 .35rem; font-size:28px; font-weight:700; letter-spacing:-.5px; }
      .profile .meta { color:var(--body); font-weight:500; font-size:15px; margin:0 0 .7rem; }
      .profile p { margin:.3rem 0; font-size:14px; }
      .profile .source { margin-top:.85rem; font-size:12.5px; color:var(--muted); }
      section { margin-top:2.5rem; }
      section > h2 { margin-bottom:.8rem; font-size:18px; font-weight:700; }
      .count { color:var(--muted); font-weight:400; }
      .votebar { display:flex; gap:.5rem; flex-wrap:wrap; }
      .vk { background:var(--surface-strong); color:var(--ink); padding:.3rem .65rem; font-size:14px; font-variant-numeric:tabular-nums; }
      .vk.ok { color:var(--ok); background:var(--ok-bg); }
      .vk.no { color:var(--no); background:var(--no-bg); }
      ul.billlist { list-style:none; padding:0; margin:0; }
      ul.billlist li { display:flex; gap:.6rem; align-items:baseline; padding:.5rem 0; border-bottom:1px solid var(--hairline); font-size:14px; }
      ul.billlist li small { margin-left:auto; color:var(--muted); font-size:12.5px; white-space:nowrap; font-variant-numeric:tabular-nums; }
      .hint { color:var(--muted); font-size:13px; }

      /* ── 의원 상세: 표결 성향(참여율·당론이탈) ── */
      .vprofile { margin-top:1.1rem; display:flex; flex-direction:column; gap:.55rem; }
      .vp-row { display:flex; align-items:baseline; gap:.6rem; flex-wrap:wrap; }
      .vp-k { min-width:6.5rem; font-size:13px; color:var(--muted); }
      .vp-v { font-size:20px; font-weight:700; letter-spacing:-.02em; font-variant-numeric:tabular-nums; }
      .vp-v.na { font-size:14px; font-weight:500; color:var(--muted); }
      .vp-sub { font-size:12.5px; color:var(--muted-soft); font-variant-numeric:tabular-nums; }
      .vp-peer { margin-left:auto; font-size:12.5px; color:var(--muted); font-variant-numeric:tabular-nums; }
      .vp-note, .oc-note { margin:.7rem 0 0; font-size:12px; color:var(--muted-soft); line-height:1.5; }

      /* ── 의원 상세: 입법 성과(처리결과 분해) ── */
      .outcome { display:flex; gap:.5rem; flex-wrap:wrap; margin:0 0 .65rem; }
      .oc { font-size:13.5px; font-weight:600; padding:.22rem .55rem; background:var(--surface-strong); color:var(--body); font-variant-numeric:tabular-nums; }
      .oc.ok { color:var(--ok); background:var(--ok-bg); }
      .oc.no { color:var(--no); background:var(--no-bg); }
      .oc.pend { color:var(--pend); background:var(--pend-bg); }
      .ocbar { display:flex; height:10px; border:1.5px solid var(--ink); }
      .ocbar span { display:block; }
      .ocbar .ok { background:var(--ok); }
      .ocbar .pend { background:var(--pend-bg); }
      .ocbar .no { background:var(--no); }

      /* ── 메인: 표결 성향 분포 띠 ── */
      .votedist { margin-top:3rem; padding-top:1.75rem; border-top:1px solid var(--hairline); }
      .votedist h2 { font-size:16px; font-weight:600; margin:0 0 1.4rem; }
      .votedist .vd-term { color:var(--muted); font-weight:400; font-size:13px; margin-left:.4rem; }
      .vd-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:2rem 2.75rem; }
      .vstrip-head { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:.55rem; }
      .vstrip-title { font-size:14px; font-weight:600; }
      .vstrip-med { font-size:12px; color:var(--muted); font-variant-numeric:tabular-nums; }
      .vstrip-bars { position:relative; display:flex; align-items:flex-end; gap:2px; height:56px; border-bottom:1.5px solid var(--ink); }
      .vstrip-bars i { flex:1; background:var(--ink); }
      .vstrip-medmark { position:absolute; top:-5px; bottom:0; width:0; border-left:1px dashed var(--link); }
      .vstrip-ends { display:flex; justify-content:space-between; margin-top:.4rem; font-size:11.5px; color:var(--muted-soft); font-variant-numeric:tabular-nums; }
      .vd-note { margin:1.6rem 0 0; font-size:12px; color:var(--muted-soft); line-height:1.6; max-width:62ch; }
    </style>

    <script is:inline>
      // 카드뉴스 좌우 이동
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.acard-top button')
        if (!btn) return
        const card = btn.closest('.acard')
        const pages = Array.from(card.querySelectorAll('.pages > .page'))
        if (pages.length < 2) return
        let cur = pages.findIndex((p) => !p.hidden)
        if (cur < 0) cur = 0
        const dir = btn.classList.contains('next') ? 1 : -1
        const nx = (cur + dir + pages.length) % pages.length
        pages[cur].hidden = true
        pages[nx].hidden = false
        const dots = card.querySelectorAll('.dots i')
        dots.forEach((d, i) => d.classList.toggle('on', i === nx))
      })

      // 원문 보기 모달
      const modal = document.getElementById('srcModal')
      const modalTitle = document.getElementById('srcModalTitle')
      const modalBody = document.getElementById('srcModalBody')
      const closeModal = () => {
        modal.hidden = true
        document.body.style.overflow = ''
      }
      document.addEventListener('click', (e) => {
        const open = e.target.closest('.src-open')
        if (open) {
          const body = open.parentElement.querySelector('.src-body')
          modalTitle.textContent = open.dataset.title || ''
          modalBody.textContent = body ? body.textContent : ''
          modalBody.scrollTop = 0
          modal.hidden = false
          document.body.style.overflow = 'hidden'
          return
        }
        // 바깥(오버레이) 클릭 또는 닫기 버튼
        if (e.target === modal || e.target.closest('#srcModalClose')) closeModal()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) closeModal()
      })
    </script>
  </body>
</html>
