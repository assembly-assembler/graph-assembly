---
import type { Card } from '../lib/data'
const base = import.meta.env.BASE_URL
const { card } = Astro.props as { card: Card }
const bills = card.bills
const v = card.votes
const pages = bills.length + 1

const resultClass = (r: string) =>
  r.includes('가결') || r.includes('반영') ? 'ok'
  : r.includes('폐기') || r.includes('철회') || r.includes('부결') ? 'no'
  : 'pend'
---

<div class="acard" data-pages={pages}>
  <div class="acard-top">
    <button class="prev" aria-label="이전">‹</button>
    <span class="dots">
      {Array.from({ length: pages }).map((_, i) => <i class={i === 0 ? 'on' : ''}></i>)}
    </span>
    <button class="next" aria-label="다음">›</button>
  </div>

  <div class="pages">
    <div class="page count">
      <div class="crow">
        <div class="who">
          <strong class="wname">{card.member?.name ?? '미상'}</strong>
          <span class="wmeta">{card.member?.party}{card.member?.district ? ` · ${card.member.district}` : ''}</span>
        </div>
        <div class="num"><span class="big">{bills.length}</span><span class="unit">건</span></div>
      </div>
      {v.total > 0 && (
        <span class="vsum">이 달 표결 {v.total} · 찬 {v.찬성} 반 {v.반대} 기 {v.기권} 불참 {v.불참}</span>
      )}
    </div>
    {bills.map((b) => (
      <div class="page bill" hidden>
        <h3 class="btitle">{b.name}</h3>
        <p class="bdesc"><span class="todo">제안이유·주요내용 — 수집 예정 (원래 → 바뀜 / 이유)</span></p>
        <p class="bfacts">소관 {b.committee || '미정'} · 공동발의 {b.coCount}인 · <span class={`tag ${resultClass(b.result)}`}>{b.result}</span></p>
      </div>
    ))}
  </div>

  <a class="tomember" href={`${base}members/${card.monaCd}`}>이 의원 보기 →</a>
</div>
