---
import Base from '../layouts/Base.astro'
import ActivityCard from '../components/ActivityCard.astro'
import VoteDist from '../components/VoteDist.astro'
import { monthView, latestMonth, inactiveMembers, unregisteredBills } from '../lib/data'

const base = import.meta.env.BASE_URL
const mv = monthView(latestMonth)!
const inactive = inactiveMembers(mv.group.month)
const unregCount = unregisteredBills.length
---

<Base title="국회의 활동을 한 눈에 — 제22대" hero={true}>
  <div class="monthnav">
    {mv.older ? <a class="arr" href={`${base}m/${mv.older.month}`}>‹</a> : <span class="arr off">‹</span>}
    <span class="mlabel">{mv.group.label}</span>
    {mv.newer ? <a class="arr" href={`${base}m/${mv.newer.month}`}>›</a> : <span class="arr off">›</span>}
  </div>

  <div class="cards-grid">
    {mv.group.cards.map((card) => <ActivityCard card={card} />)}
  </div>

  <section class="inactive">
    <h2>{mv.group.label} 대표발의 0건 <span class="count">{inactive.length}명</span></h2>
    <ul class="namelist">
      {inactive.map((m) => (
        <li><a href={`${base}members/${m.monaCd}`}>{m.name}</a><small>{m.party}</small></li>
      ))}
    </ul>
  </section>

  {unregCount > 0 && (
    <section class="unreg-link">
      <h2><a href={`${base}unregistered`}>제안이유 미등록 발의 <span class="count">{unregCount}건</span> →</a></h2>
      <p class="hint">발의는 됐지만 의안정보시스템에 제안이유·주요내용 원문이 아직 없는 법안 모음.</p>
    </section>
  )}

  <VoteDist />
</Base>
