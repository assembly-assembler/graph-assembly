---
import Base from '../layouts/Base.astro'
import { unregisteredBills } from '../lib/data'

const base = import.meta.env.BASE_URL
const bills = unregisteredBills

const resultClass = (r: string) =>
  r.includes('가결') || r.includes('반영') ? 'ok'
  : r.includes('폐기') || r.includes('철회') || r.includes('부결') ? 'no'
  : 'pend'
---

<Base title="제안이유 미등록 발의 — 국회의 활동을 한 눈에">
  <a class="back" href={base}>← 의정활동 피드</a>

  <section>
    <h2>제안이유·주요내용 미등록 발의 <span class="count">{bills.length}건</span></h2>
    <p class="oc-note">
      발의는 접수됐으나 의안정보시스템(likms)에 <b>제안이유·주요내용 원문이 등록되지 않은</b> 법안.
      원문이 없어 카드 요약을 만들 수 없음(없는 내용을 지어내지 않음). 대부분 처리 전(계류) 상태이며,
      국회가 원문을 등록하면 다음 적재에서 자동으로 채워지고 이 목록에서 빠짐.
      출처 · 열린국회정보(발의 메타) + 의안정보시스템(원문 유무).
    </p>
    <ul class="billlist">
      {bills.map((b) => (
        <li>
          <span class={`tag ${resultClass(b.result)}`}>{b.result}</span>
          {b.link ? <a href={b.link} target="_blank" rel="noopener">{b.name}</a> : <span>{b.name}</span>}
          <small>
            {b.member ? <a href={`${base}members/${b.rstMona}`}>{b.member.name}</a> : (b.rstName ?? '미상')}
            {b.member?.party ? ` · ${b.member.party}` : ''} · {b.date}
          </small>
        </li>
      ))}
    </ul>
  </section>
</Base>
